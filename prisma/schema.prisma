generator client {
  provider = "prisma-client"
  output   = "../src/shared/lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             Int    @id @default(autoincrement())
  fullName       String @map("full_name")
  email          String @unique
  hashedPassword String @map("password")

  @@map("users")
}
